{
  "realm": "wms-dev",
  "enabled": true,
  "displayName": "WMS Development",
  "registrationAllowed": false,
  "resetPasswordAllowed": true,
  "rememberMe": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "bruteForceProtected": true,
  "accessTokenLifespan": 300,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 28800,
  "offlineSessionMaxLifespanEnabled": true,
  "offlineSessionMaxLifespan": 86400,
  "otpPolicyType": "totp",
  "otpPolicyAlgorithm": "HmacSHA256",
  "otpPolicyDigits": 6,
  "otpPolicyPeriod": 30,
  "clients": [
    {
      "clientId": "wms-api",
      "name": "WMS API",
      "enabled": true,
      "bearerOnly": true,
      "protocol": "openid-connect"
    },
    {
      "clientId": "wms-web",
      "name": "WMS Supervisor Web",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "protocol": "openid-connect",
      "redirectUris": ["http://localhost:3000/*"],
      "webOrigins": ["http://localhost:3000"],
      "attributes": {"pkce.code.challenge.method": "S256"},
      "defaultClientScopes": ["wms-context", "wms-api-access"]
    },
    {
      "clientId": "wms-mobile",
      "name": "WMS Android",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "protocol": "openid-connect",
      "redirectUris": ["com.wms.mobile:/oauth2redirect"],
      "attributes": {"pkce.code.challenge.method": "S256"},
      "defaultClientScopes": ["wms-context", "wms-api-access"]
    }
  ],
  "clientScopes": [
    {
      "name": "wms-context",
      "description": "Tenant and operational scopes from managed user attributes.",
      "protocol": "openid-connect",
      "attributes": {"include.in.token.scope": "true", "display.on.consent.screen": "false"},
      "protocolMappers": [
        {
          "name": "tenant-id",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "config": {"user.attribute": "tenant_id", "claim.name": "tenant_id", "jsonType.label": "String", "access.token.claim": "true", "id.token.claim": "true", "multivalued": "false"}
        },
        {
          "name": "warehouse-ids",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "config": {"user.attribute": "warehouse_ids", "claim.name": "warehouse_ids", "jsonType.label": "String", "access.token.claim": "true", "multivalued": "true"}
        },
        {
          "name": "owner-ids",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "config": {"user.attribute": "owner_ids", "claim.name": "owner_ids", "jsonType.label": "String", "access.token.claim": "true", "multivalued": "true"}
        },
        {
          "name": "zone-ids",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "config": {"user.attribute": "zone_ids", "claim.name": "zone_ids", "jsonType.label": "String", "access.token.claim": "true", "multivalued": "true"}
        }
      ]
    },
    {
      "name": "wms-api-access",
      "description": "Audience and WMS API client roles required by web and mobile clients.",
      "protocol": "openid-connect",
      "attributes": {"include.in.token.scope": "false", "display.on.consent.screen": "false"},
      "protocolMappers": [
        {
          "name": "wms-api-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "config": {"included.client.audience": "wms-api", "access.token.claim": "true", "id.token.claim": "false", "introspection.token.claim": "true"}
        },
        {
          "name": "wms-api-client-roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-client-role-mapper",
          "config": {"claim.name": "resource_access.${client_id}.roles", "multivalued": "true", "jsonType.label": "String", "access.token.claim": "true", "id.token.claim": "false", "introspection.token.claim": "true"}
        }
      ]
    }
  ],
  "roles": {
    "realm": [
      {
        "name": "wms-operator",
        "composite": true,
        "composites": {"client": {"wms-api": ["wms.task.read_assigned", "wms.task.execute", "wms.receipt.execute", "wms.putaway.execute", "wms.pick.execute"]}}
      },
      {
        "name": "wms-supervisor",
        "composite": true,
        "composites": {
          "realm": ["wms-operator"],
          "client": {"wms-api": ["wms.task.reassign", "wms.short_pick.approve", "wms.pack.execute", "wms.shipment.dispatch", "wms.inventory.read", "wms.supervisor.read", "wms.inbound.read", "wms.outbound.read", "wms.outbound.release", "wms.outbound.pack", "wms.outbound.dispatch", "wms.integration.read"]}
        }
      },
      {
        "name": "wms-manager",
        "composite": true,
        "composites": {"realm": ["wms-supervisor"], "client": {"wms-api": ["wms.audit.read"]}}
      },
      {
        "name": "wms-admin",
        "composite": true,
        "composites": {"client": {"wms-api": ["wms.layout.manage", "wms.master.manage", "wms.security.manage"]}}
      },
      {
        "name": "wms-integrator",
        "composite": true,
        "composites": {"client": {"wms-api": ["wms.integration.ingest", "wms.integration.read", "wms.integration.reprocess"]}}
      },
      {
        "name": "wms-auditor",
        "composite": true,
        "composites": {"client": {"wms-api": ["wms.inventory.read", "wms.integration.read", "wms.audit.read"]}}
      },
      {
        "name": "wms-support",
        "composite": true,
        "composites": {"client": {"wms-api": ["wms.integration.read", "wms.integration.reprocess"]}}
      }
    ],
    "client": {
      "wms-api": [
        {"name": "wms.task.read_assigned"},
        {"name": "wms.task.execute"},
        {"name": "wms.task.reassign"},
        {"name": "wms.receipt.execute"},
        {"name": "wms.putaway.execute"},
        {"name": "wms.pick.execute"},
        {"name": "wms.short_pick.approve"},
        {"name": "wms.pack.execute"},
        {"name": "wms.shipment.dispatch"},
        {"name": "wms.inventory.read"},
        {"name": "wms.supervisor.read"},
        {"name": "wms.inbound.read"},
        {"name": "wms.outbound.read"},
        {"name": "wms.outbound.release"},
        {"name": "wms.outbound.pack"},
        {"name": "wms.outbound.dispatch"},
        {"name": "wms.layout.manage"},
        {"name": "wms.master.manage"},
        {"name": "wms.integration.ingest"},
        {"name": "wms.integration.read"},
        {"name": "wms.integration.reprocess"},
        {"name": "wms.audit.read"},
        {"name": "wms.security.manage"}
      ]
    }
  },
  "requiredActions": [
    {"alias": "CONFIGURE_TOTP", "name": "Configure OTP", "providerId": "CONFIGURE_TOTP", "enabled": true, "defaultAction": false, "priority": 10}
  ]
}
