# Development-only example. Copy to .env and replace every change-me value.
COMPOSE_PROJECT_NAME=wms
TZ=America/Asuncion

POSTGRES_DB=wms
POSTGRES_USER=wms_dev
POSTGRES_PASSWORD=change-me-postgres
POSTGRES_PORT=5432
WMS_API_DB_PASSWORD=change-me-wms-api
WMS_WORKER_DB_PASSWORD=change-me-wms-worker
WMS_WEBHOOK_SECRET=change-me-webhook-signature

RABBITMQ_USER=wms_dev
RABBITMQ_PASSWORD=change-me-rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

REDIS_PASSWORD=change-me-redis
REDIS_PORT=6379

KEYCLOAK_ADMIN=wms_admin
KEYCLOAK_ADMIN_PASSWORD=change-me-keycloak
KEYCLOAK_PORT=8080
KEYCLOAK_MANAGEMENT_PORT=9000

MINIO_ROOT_USER=wms_minio
MINIO_ROOT_PASSWORD=change-me-minio
MINIO_API_PORT=9001
MINIO_CONSOLE_PORT=9002
MINIO_BUCKET=wms-evidence
MOCK_ERP_PORT=9999

OTEL_GRPC_PORT=4317
OTEL_HTTP_PORT=4318
OTEL_HEALTH_PORT=13133
OTEL_METRICS_PORT=9464
PROMETHEUS_PORT=9090
LOKI_PORT=3100
TEMPO_PORT=3200
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=wms_admin
GRAFANA_ADMIN_PASSWORD=change-me-grafana

WMS_API_PORT=8081
WMS_WEB_PORT=3000
NEXT_PUBLIC_WMS_API_URL=http://localhost:8081
ASPNETCORE_ENVIRONMENT=Development
WMS_API_IMAGE=ghcr.io/example/wms-api
WMS_WORKER_IMAGE=ghcr.io/example/wms-worker
